# Runtime
APP_NAME=X-CDS
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=info

# Local persistence
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=xcds_biomedical
BM25_CORPUS_PATH=./data/bm25_corpus.jsonl

# Dense embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Cross-encoder re-ranking
CROSS_ENCODER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_DEVICE=cpu
RERANK_TOP_K=5

# External model providers
GCP_PROJECT_ID=
GCP_REGION=global
GOOGLE_APPLICATION_CREDENTIALS=gcp-key.json
EVAL_EMBEDDING_MODEL=models/text-embedding-004
EVAL_LLM_MODEL=gemini-2.5-pro
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=0.1

# LangGraph generation
LANGGRAPH_MAX_GENERATION_ATTEMPTS=3
CITATION_MIN_TOKEN_OVERLAP=0.25
